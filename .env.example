# --- App ---
APP_ENV=development
APP_DEBUG=true

# --- Frontend ---
# Where the browser should reach the FastAPI backend.
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# --- Backend / API ---
# CORS_ORIGINS may be a comma-separated list.
CORS_ORIGINS=http://localhost:3004

# --- NeonDB / Postgres ---
# API uses asyncpg, worker auto-converts to psycopg2.
# Pooler URL works for queries; if startup fails on missing columns, use the
# direct host (ep-xxxx.region.aws.neon.tech, not ep-xxxx-pooler...) for DATABASE_URL.
# Example: postgresql+asyncpg://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@host/dbname?sslmode=require

# --- Redis / Queue ---
REDIS_URL=redis://localhost:6379/0
QUEUE_NAME=eyecontact
# Fast queue for SAM2 mask previews — doesn't get stuck behind heavy renders.
MASK_QUEUE_NAME=eyecontact-fast

# --- Cloudinary ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_UPLOAD_FOLDER=eyecontact

# --- Eye-contact pipeline tuning ---
# 0..~1.2  How fully the iris is moved onto the camera-facing target.
GAZE_WARP_STRENGTH=1.0
# 0..1     EMA factor; lower = more temporal smoothing, higher = snappier.
TEMPORAL_SMOOTH=0.5
# Hard cap on the per-frame iris shift, in iris radii.
MAX_SHIFT_IRIS_RADII=1.4

# --- Beauty defaults (used when payload omits the field) ---
DEFAULT_SKIN_SMOOTH=0.5
DEFAULT_TEETH_WHITEN=0.5
DEFAULT_EYE_BRIGHTEN=0.4

# --- Background segmentation ---
# Set to false to disable SAM2 entirely (auto mode still works).
SAM2_ENABLED=true
SAM2_MODEL=sam2_hiera_tiny
# 'cpu' or 'cuda'. CPU is multiples slower than GPU; recommend GPU for
# clips longer than ~30s when SAM2 mode is selected.
SAM2_DEVICE=cpu
SAM2_WEIGHTS_DIR=/models/sam2

# --- Encoding ---
# When true, transparent backgrounds are exported as VP9 + alpha WebM.
ALLOW_WEBM_ALPHA=true

MAX_UPLOAD_BYTES=209715200
